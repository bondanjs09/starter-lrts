{
    "compilerOptions": {
        "target": "ESNext",
        "lib": ["DOM", "DOM.Iterable", "ESNext"],
        "module": "ESNext",
        "jsx": "react-jsx",

        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,

        "strict": true,
        "noEmit": true,

        "baseUrl": ".",
        "paths": {
            "@/*": ["resources/js/*"]
        }
    },
    "include": ["resources/js/**/*"]
}
